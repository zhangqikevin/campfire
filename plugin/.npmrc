# Pin to the public npm registry so install works regardless of the user's
# global registry config. The @openuidev/* packages used by the renderer are
# only mirrored on registry.npmjs.org — some Chinese mirrors (cnpm, npmmirror,
# taobao) don't have them, and Campfire fails to install without this.
registry=https://registry.npmjs.org/
@openuidev:registry=https://registry.npmjs.org/
