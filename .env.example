# Database — local Postgres via docker-compose by default.
DATABASE_URL=postgresql://campfire:campfire@localhost:5432/campfire

# Auth.js v5 — generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-openssl-rand-base64-32

# Allow Auth.js to trust the host header. Required for non-Vercel deployments
# and for running behind a reverse proxy. Set to "false" in production if you
# explicitly set AUTH_URL.
AUTH_TRUST_HOST=true
